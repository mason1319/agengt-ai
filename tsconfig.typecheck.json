{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "functions/api/v1/**/*.js",
    "scripts/*.js",
    "src/config/*.js",
    "src/seedData.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "output"
  ]
}
