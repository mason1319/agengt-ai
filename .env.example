# Frontend runtime mode
VITE_DATA_SOURCE=api
VITE_API_BASE=/api
VITE_API_TIMEOUT_MS=4000

# Optional API token (used only for single-role API mode; when VITE_INITIAL_ROLE is set, frontend fetch is role-based)
VITE_API_TOKEN=

# Optional: lock default role in API mode (founder|teacher|parent|student|platform)
VITE_INITIAL_ROLE=founder

# Optional build info
VITE_APP_ENV=local

# Optional backend demo flag (开启后 /api/v1/auth/login 可继续返回演示角色 token)
ALLOW_DEMO_LOGIN=false

# AI 接入基础配置（默认模拟；接真实模型时改成 provider 模式）
# AI_MODE=provider
# AI_PROVIDER=your-provider-name
# AI_BASE_URL=https://your-provider.example/v1
# AI_MODEL=your-model-name
# AI_API_KEY=请通过 wrangler secret put AI_API_KEY 注入，不要明文写入仓库
#
# 常见预设参考：
# DeepSeek  -> AI_PROVIDER=deepseek / AI_BASE_URL=https://api.deepseek.com / AI_MODEL=deepseek-chat
# Qwen      -> AI_PROVIDER=qwen / AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1 / AI_MODEL=qwen-plus
# Moonshot  -> AI_PROVIDER=moonshot / AI_BASE_URL=https://api.moonshot.cn/v1 / AI_MODEL=moonshot-v1-8k
# 豆包      -> AI_PROVIDER=doubao / AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3 / AI_MODEL=ep-202406
# 智谱      -> AI_PROVIDER=zhipu / AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4 / AI_MODEL=glm-4-plus

# Optional: 切换到 mock 后可复用原始演示流程
# VITE_DATA_SOURCE=mock
